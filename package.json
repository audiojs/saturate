{
  "name": "@audio/saturate",
  "version": "1.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Saturation — umbrella for @audio/saturate-* atoms (tape, tube, transistor, waveshaper, multiband)",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "audio",
    "dsp",
    "saturation",
    "tape",
    "tube",
    "harmonics"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "dependencies": {
    "@audio/saturate-waveshaper": "^1.0.0",
    "@audio/saturate-tube": "^1.0.0",
    "@audio/saturate-transistor": "^1.0.0",
    "@audio/saturate-tape": "^1.0.0",
    "@audio/saturate-multiband": "^1.0.0"
  },
  "devDependencies": {
    "tst": "^9.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/saturate.git"
  }
}

{
  "name": "@audio/saturate-transistor",
  "version": "1.1.3",
  "description": "Transistor/console saturation — odd-symmetric cubic, 3rd-harmonic dominant",
  "type": "module",
  "sideEffects": false,
  "main": "transistor.js",
  "exports": {
    ".": "./transistor.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "transistor.js",
    "shape.js",
    "audio.js",
    "audio.d.ts",
    "transistor.d.ts"
  ],
  "dependencies": {
    "@audio/resample-sinc": "^1.0.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "saturation",
    "transistor"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/saturate.git",
    "directory": "packages/saturate-transistor"
  },
  "funding": "https://github.com/sponsors/audiojs",
  "types": "transistor.d.ts"
}
